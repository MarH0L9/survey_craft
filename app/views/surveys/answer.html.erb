<!-- Public Survey View for End Users -->
<div class="text-center mb-5">
  <h1 class="display-5 text-dark fw-bold"><%= @survey.title %></h1>
  <p class="lead text-muted"><%= @survey.description %></p>
</div>

<!-- Form to submit all answers at once -->
<%= form_with(url: answers_path, method: :post, local: true) do |form| %>
  
  <% @survey.questions.each_with_index do |question, index| %>
    <div class="card mb-4 shadow-sm border-0 bg-white p-4">
      <h5 class="card-title fw-bold text-secondary mb-3">
        <%= index + 1 %>. <%= question.content %>
      </h5>

      <div class="card-body p-0">
        <% if question.question_type == 'satisfaction' %>
          <!-- 1-5 Satisfaction Radio Buttons styled with Bootstrap Button Group -->
          <div class="d-flex justify-content-between mx-auto" style="max-width: 400px;">
            <span class="text-danger fw-bold align-self-center">Poor</span>
            
            <div class="btn-group" role="group" aria-label="Satisfaction rating">
              <% (1..5).each do |num| %>
                <input type="radio" class="btn-check" name="answers[<%= question.id %>]" id="q_<%= question.id %>_<%= num %>" value="<%= num %>" required>
                <label class="btn btn-outline-primary px-3 py-2 fw-bold" for="q_<%= question.id %>_<%= num %>"><%= num %></label>
              <% end %>
            </div>

            <span class="text-success fw-bold align-self-center">Excellent</span>
          </div>

        <% else %>
          <!-- Text response field -->
          <%= text_area_tag "answers[#{question.id}]", nil, rows: 3, placeholder: "Type your answer here...", class: "form-control", required: true %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Submit Actions -->
  <div class="text-center mt-5">
    <%= form.submit "Submit Survey", class: "btn btn-primary btn-lg px-5 shadow" %>
    <div class="mt-3">
      <%= link_to "Back to Admin Dashboard", survey_path(@survey), class: "btn btn-link btn-sm text-decoration-none text-muted" %>
    </div>
  </div>

<% end %>