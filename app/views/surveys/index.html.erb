<!-- Main Admin Dashboard Header -->
<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
  <div>
    <h1 class="h2 text-dark fw-bold mb-0">Survey Analytics Dashboard</h1>
    <p class="text-muted mb-0">Overview of all active campaigns and submission metrics.</p>
  </div>
  <%= link_to "Create New Survey", new_survey_path, class: "btn btn-primary shadow-sm" %>
</div>

<!-- Success/Alert Notifications -->
<% if notice %>
  <div class="alert alert-success shadow-sm mb-4" role="alert"><%= notice %></div>
<% end %>

<!-- Surveys Grid Metrics View -->
<div class="row g-4">
  <% @surveys.each do |survey| %>
    <div class="col-md-6 col-lg-4">
      <div class="card h-100 shadow-sm border-0 bg-white">
        <div class="card-body p-4 d-flex flex-column">
          <h5 class="card-title fw-bold text-dark mb-1"><%= survey.title %></h5>
          <p class="card-text text-muted small mb-4 flex-grow-1"><%= truncate(survey.description, length: 90) %></p>
          
          <!-- Key Performance Indicators (KPIs) -->
          <div class="row g-2 text-center bg-light rounded p-2 mb-3">
            <div class="col-6 border-end">
              <span class="d-block text-secondary small fw-semibold">Questions</span>
              <span class="fs-4 fw-bold text-dark"><%= survey.questions.count %></span>
            </div>
            <div class="col-6">
              <span class="d-block text-secondary small fw-semibold">Submissions</span>
              <!-- We calculate unique participants by checking the max answers on a single question -->
              <% max_responses = survey.questions.map { |q| q.answers.count }.max || 0 %>
              <span class="fs-4 fw-bold text-primary"><%= max_responses %></span>
            </div>
          </div>

          <!-- Quick Actions -->
          <div class="d-grid gap-2 mt-auto">
            <%= link_to "View Analytics & Responses", survey_path(survey), class: "btn btn-outline-dark btn-sm fw-semibold" %>
            <%= link_to "Live Survey Link", answer_survey_path(survey), class: "btn btn-link btn-sm text-decoration-none text-muted", target: "_blank" %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>